# =============================================================================
# Fundle — copy to fundle.config.env and adjust locally (not committed to git)
# Sync naar apps/api/.env en apps/web/.env.local gebeurt automatisch bij npm run dev
# =============================================================================

# 1 = elke pagina-refresh reset gokken en bouwt puzzel opnieuw (alleen voor dev)
# 0 = normale daily sessie (gokken blijven bewaard)
DEBUG_FRESH=0

# --- API ---
DATABASE_URL=sqlite+pysqlite:///./fundle.db
CORS_ORIGINS=http://localhost:3000

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Puzzle selection strategy ---
# Price buckets for daily puzzle selection.
# Format: min:max:weight (semicolon-separated). Max can be empty for uncapped.
# Weights should sum to 1.0 (100%). If not, weights are normalized automatically with a warning.
PRICE_BUCKETS=150000:400000:0.20;400000:600000:0.30;600000:900000:0.30;900000:1400000:0.15;1400000::0.05
