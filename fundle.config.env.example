# =============================================================================
# Fundle — copy to fundle.config.env and adjust locally (not committed to git)
# Sync naar apps/api/.env en apps/web/.env.local gebeurt automatisch bij npm run dev
# =============================================================================

# 1 = elke pagina-refresh reset gokken (alleen voor dev)
# 0 = normale daily sessie (gokken blijven bewaard in localStorage)
DEBUG_FRESH=0

# --- Supabase (puzzle builder, server-side) ---
# Project URL en de SERVICE ROLE key (geheim! alleen voor de build-script en
# GitHub Actions). Vind je in Supabase: Project Settings > API.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Supabase (frontend, public) ---
# De anon/public key — veilig om in de browser te gebruiken (RLS beschermt writes).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# --- Puzzle selection strategy ---
# Price buckets for daily puzzle selection.
# Format: min:max:weight (semicolon-separated). Max can be empty for uncapped.
# Weights should sum to 1.0 (100%). If not, weights are normalized automatically with a warning.
# Boundaries are exclusive on the upper end: 150000:400000 means [150000, 400000).
PRICE_BUCKETS=150000:400000:0.20;400000:600000:0.30;600000:900000:0.30;900000:1400000:0.15;1400000::0.05
